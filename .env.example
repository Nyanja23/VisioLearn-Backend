# Database connection string
# Format: postgresql://<username>:<password>@localhost:5432/<database_name>
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/visiolearn

# JWT Secret Key - MUST be a cryptographically random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# JWT Algorithm
ALGORITHM=HS256

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=90

# CORS allowed origins (comma-separated)
# Example: https://admin.visiolearn.com,https://app.visiolearn.com
ALLOWED_ORIGINS=http://localhost:3000

# Environment (development, staging, production)
ENVIRONMENT=development
